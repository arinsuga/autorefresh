DEVMODE=true
APP_NAME="Authapi"
APP_ENV=local
APP_KEY=RUN_PHP_ARTISAN_KEY_GENERATE
APP_DEBUG=true
APP_URL=http://authapi.localhost
APP_COMPANY_NAME=Company_Name
APP_COMPANY_ADDRESS1=Company_Address_1
APP_COMPANY_ADDRESS2=Company_Address_2
APP_COMPANY_CITY=Company_City
APP_COMPANY_COUNTRY=Company_Country
APP_COMPANY_COPYRIGHT="&copy; 2025 Company_Name"

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=authdb
DB_USERNAME=authusr
DB_PASSWORD=authpass

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

# BASIC ROLE
# ROLE_MASTER=masterrole
# ROLE_MASTER_ID=1
# ROLE_SUPER=superrole
# ROLE_SUPER_ID=2
# ROLE_ADMIN=adminrole
# ROLE_ADMIN_ID=3
# ROLE_ADMIN=userrole
# ROLE_ADMIN_ID=4

# AUTOREFRESH ROLE
ROLE_MASTER=masterrole
ROLE_MASTER_ID=1
ROLE_SUPER=arf-super
ROLE_SUPER_ID=5
ROLE_ADMIN=arf-admin
ROLE_ADMIN_ID=6

# LOGO=logo.png
# LOGO_LANDSCAPE=logo_landscape.png
# LOGO_ICON=logo_icon.png
# FAVICON=favicon.png

# JWT - authapi
JWT_SECRET=RUN_PHP_ARTISAN_JWT_SECRET
# JWT Time-to-Leave 1 year (365 days)
JWT_TTL=525600 
# JWT refresh Time-to-Leave 1 year (365 days)
JWT_REFRESH_TTL=525600